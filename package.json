{
  "name": "qwanvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "npm run build:app && node scripts/generate.mjs projects/package-json",
    "build:html": "npm run build:app && node scripts/generate.mjs projects/package-json --no-pdf",
    "build:app": "npm run typecheck && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch": "node scripts/watch.mjs projects/package-json",
    "test": "npm run build:app && vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "typescript": "^5.5.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
